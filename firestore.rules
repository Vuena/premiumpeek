rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: check if user is admin
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: check if user owns the document
    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Helper: check if update doesn't change protected fields
    function noProtectedFieldChanges(fields) {
      return !request.resource.data.keys().hasAny(fields);
    }

    // Users: owner can't change role; admin can do anything
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId);
      allow update: if (isOwner(userId) && noProtectedFieldChanges(["role"])) || isAdmin();
      allow delete: if isAdmin();
    }

    // Packs: status only admin can change; member changes allowed for auth users
    match /packs/{packId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth() && (request.resource.data.status == resource.data.status || isAdmin());
      allow delete: if isAdmin();
    }

    // Apps
    match /apps/{appId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isOwner(resource.data.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Transactions
    match /transactions/{txId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAdmin();
    }

    // Testing activity: only owner or admin can update
    match /testingActivity/{activityId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isOwner(resource.data.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuth();
      allow delete: if isAdmin();
    }

    // Tester logs: admin-only update
    match /testerLogs/{logId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
    }

    // Complaints
    match /complaints/{complaintId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Screenshots
    match /screenshots/{screenshotId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow delete: if isAdmin();
    }

    // Audit logs (server-side only via Admin SDK)
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
